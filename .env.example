TOKEN_ENCRYPTION_KEY=

# SharePoint
SHAREPOINT_SITE_URL=
SHAREPOINT_DRIVE_NAME=SERVEUR

# Connexion Postgres directe (MCP Cursor / scripts — ne pas exposer côté client)
